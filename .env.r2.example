# Cloudflare R2 Storage Configuration
# Get these values from your Cloudflare R2 dashboard

# Your Cloudflare Account ID
R2_ACCOUNT_ID=your_account_id_here

# R2 API Token (Create an R2 API Token in Cloudflare dashboard)
# The token needs 'Object Read & Write' permissions
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# The name of your R2 bucket
R2_BUCKET_NAME=dispatch-documents

# Optional: Public URL for your R2 bucket (if you set up a custom domain)
# If not set, presigned URLs will be used instead
# R2_PUBLIC_URL=https://your-custom-domain.com